# YourCA Configuration
# Copy this to .env or set as environment variables

# Required: DeepSeek API key (get one at https://platform.deepseek.com/api_keys)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# Optional: Override the default model (deepseek-chat, deepseek-reasoner)
YOURCA_MODEL=deepseek-chat
